/target

# BlastGuard cache (produced when binary runs against a project)
/.blastguard/
tests/fixtures/*/.blastguard/

# Cargo long-type-overflow artifacts (cargo 1.90+ writes these on clippy pedantic runs)
*.long-type-*.txt
/rust_out

# Log files
*.log

# Secrets — never commit API keys
.env
.env.*
!.env.example
*.env.local
bench/.env
bench/.env.*
!bench/.env.example

# Benchmark harness
bench/results/
bench/.venv/
bench/__pycache__/
bench/**/__pycache__/
bench/.pytest_cache/
bench/.evaluator/
bench/.sweagent-repo/

# Microbench rollout artifacts — large .jsonl files, one per run.
# One file intentionally kept as the grader's smoke-test baseline.
bench/runs/
!bench/runs/20260420-014947-chain-search-to-graph.jsonl

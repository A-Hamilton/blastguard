# Copy this file to `.env` (which is gitignored) and fill in your keys.
# `.env` is loaded by tools like `uv run --env-file` and standard shell
# `source`. The harness itself reads the env vars directly via os.environ.
#
# NEVER commit the populated .env file. Rotate any key that ends up in
# git history or chat transcripts.

# Anthropic — direct API for Claude models.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenRouter — unified proxy for Claude / GLM / DeepSeek / Qwen / etc.
# Get one at https://openrouter.ai/keys
# With just this key you can run both Claude and GLM via --provider openai.
OPENROUTER_API_KEY=
